# HTTP server port
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/taskmanager?sslmode=disable

# Secret used to sign JWTs - use a long, random value in production
JWT_SECRET=change-me-to-a-random-secret

# Origin allowed to make cross-origin requests (the frontend's URL)
ALLOWED_ORIGIN=http://localhost:3000

# Directory where uploaded task attachments are stored
STORAGE_DIR=./data/attachments
